# 数据库配置
DATABASE_URL=mysql+aiomysql://family:familypass@localhost:3306/family_ai?charset=utf8mb4

# JWT 配置（请修改为你自己的密钥）
JWT_SECRET=change-this-to-a-long-random-secret-key-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# AES 加密密钥（必须是 32 字节的 base64 字符串）
ENCRYPTION_AES_KEY=please-change-this-to-32-byte-key-please

# LLM 配置（可选，不配置时使用本地模板 fallback）
# 支持 OpenAI 兼容 API，例如 DeepSeek、OpenAI 等
# 前端不持有 API Key，所有 LLM 调用只走后端
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=45
LLM_FALLBACK_ENABLED=true
LLM_MAX_TOKENS=800

# SQLAlchemy
SQLALCHEMY_ECHO=false
SQLALCHEMY_POOL_SIZE=10
