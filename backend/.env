# 数据库配置
DATABASE_URL=mysql+aiomysql://family:familypass@localhost:3306/family_ai?charset=utf8mb4

# JWT 配置
JWT_SECRET=dev-secret-change-in-production-abc123xyz789
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# AES 加密密钥（32 字节）
ENCRYPTION_AES_KEY=dev-only-aes-key-change-in-production-ple

# LLM 配置（可选，不配置时使用本地模板）
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_FALLBACK_ENABLED=true
LLM_MAX_TOKENS=800

# SQLAlchemy
SQLALCHEMY_ECHO=false
SQLALCHEMY_POOL_SIZE=10
